# =============================================================================
# DevPulse — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Superuser password for the postgres container (used during first init only)
POSTGRES_PASSWORD=changeme

# App database role password — must match docker/init/01_init.sql
# If you change this, update the init SQL or recreate the volume.
APP_DB_PASSWORD=secret

# ── Application ───────────────────────────────────────────────────────────────
# Port exposed on the host machine
SERVER_PORT=8000

# Log level: error | warn | info | debug | trace
RUST_LOG=info

# Admin API token — protects all /api/* routes (except /api/ingest).
# Set to a strong random string in production. Leave blank to disable (dev only).
# Generate one with: openssl rand -hex 32
ADMIN_TOKEN=

# Max events accepted per API key per 60-second window (default: 120)
INGEST_RATE_LIMIT=120

# Delete events older than this many days (default: 90). Set 0 to disable.
EVENT_RETENTION_DAYS=90

# ── SMTP — Email Alerts (optional) ───────────────────────────────────────────
# Leave SMTP_HOST blank to disable email alerts entirely.
#
# For production (e.g. SendGrid, Postmark, Mailgun, Gmail):
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.xxxxxxxxxxxx
#   SMTP_FROM=alerts@yourdomain.com
#
# For local dev with Mailpit (included in docker-compose.dev.yaml):
#   SMTP_HOST=mailpit
#   SMTP_PORT=1025
#   SMTP_USER=
#   SMTP_PASS=
#   SMTP_FROM=devpulse@localhost

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=devpulse@localhost
