  "query": "\n        SELECT\n            i.id, i.project_id, i.fingerprint, i.title,\n            i.level, i.status, i.first_seen, i.last_seen, i.event_count,\n            p.name AS project_name, p.platform\n        FROM issues i\n        JOIN projects p ON p.id = i.project_id\n        WHERE i.id = $1\n        ",
