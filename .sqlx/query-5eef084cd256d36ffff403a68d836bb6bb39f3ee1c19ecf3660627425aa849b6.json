  "query": "\n        UPDATE alerts SET\n            enabled          = COALESCE($1, enabled),\n            cooldown_minutes = COALESCE($2, cooldown_minutes),\n            endpoint         = COALESCE($3, endpoint)\n        WHERE id = $4\n        RETURNING id, channel, endpoint, enabled, cooldown_minutes\n        ",
